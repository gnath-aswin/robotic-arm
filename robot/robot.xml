<mujoco model="TRLC-DK1-Follower">

  <compiler angle="radian" meshdir="../robot/meshes/collision"/>

    <option gravity="0 0 -9.81"/>

    <default>
        <joint damping="2"/>
        <geom material="robot_mat"/>
    </default>

    <asset>
        <mesh name="base_link" file="base_link.stl"/>
        <mesh name="link1-2" file="link1-2.stl"/>
        <mesh name="link2-3" file="link2-3.stl"/>
        <mesh name="link3-4" file="link3-4.stl"/>
        <mesh name="link4-5" file="link4-5.stl"/>
        <mesh name="link5-6" file="link5-6.stl"/>
        <mesh name="link6-7" file="link6-7.stl"/>
        <mesh name="finger_left" file="finger_left.stl"/>
        <mesh name="finger_right" file="finger_right.stl"/>

        <material name="robot_mat" rgba="0.2 0.6 0.8 1"/>
    </asset>

    <worldbody>
      <geom type="mesh" mesh="base_link" material="robot_mat"/>

        <body name="link1-2" pos="0 0 0.0615">
          <inertial pos="0.0054231 0 0.017086" quat="0.653281 0.653281 -0.270598 0.270598" mass="0.5965" diaginertia="9e-05 7e-05 3e-05"/>
          <joint name="joint1" pos="0 0 0" axis="0 0 1" range="-2.0944 2.0944" actuatorfrcrange="-100 100"/>
          <geom type="mesh" mesh="link1-2"/>

          <body name="link2-3" pos="0.02 0 0.0385">
            <inertial pos="-0.132 0 0" quat="0 0.707107 0 0.707107" mass="0.9084" diaginertia="0.01605 0.01599 0.00051"/>
            <joint name="joint2" pos="0 0 0" axis="0 1 0" range="-0.01 3.14159" actuatorfrcrange="-100 100"/>
            <geom type="mesh" mesh="link2-3"/>

            <body name="link3-4" pos="-0.264 0 0">
              <inertial pos="0.18531 0.00068376 0.051638" quat="0.162774 0.718019 0.185661 0.650756" mass="0.7089" diaginertia="0.004243 0.00422646 0.000320548"/>
              <joint name="joint3" pos="0 0 0" axis="0 -1 0" range="-0.01 4.71239" actuatorfrcrange="-100 100"/>
              <geom type="mesh" mesh="link3-4"/>

              <body name="link4-5" pos="0.244004 0 0.059971">
                <inertial pos="0.040231 0.0044807 0.035335" quat="0.911288 -0.0751532 0.308689 -0.261949" mass="0.3995" diaginertia="0.000275643 0.00021286 7.14977e-05"/>
                <joint name="joint4" pos="0 0 0" axis="0 -1 0" range="-1.95 1.5708" actuatorfrcrange="-20 20"/>
                <geom type="mesh" mesh="link4-5"/>

                <body name="link5-6" pos="0.061868 0 0.0425">
                  <inertial pos="0.003612 0 0" quat="0.998188 0 -0.0601752 0" mass="0.4121" diaginertia="0.000838471 0.00082 0.000251529"/>
                  <joint name="joint5" pos="0 0 0" axis="0 0 -1" range="-1.5708 1.5708" actuatorfrcrange="-20 20"/>
                  <geom type="mesh" mesh="link5-6"/>

                  <body name="link6-7" pos="0.032 0 -0.0425">
                    <inertial pos="0.041697 2.4368e-05 0.00014464" quat="0.5 0.5 -0.5 0.5" mass="0.5" diaginertia="0.0005 0.00038 0.00028"/>
                    <joint name="joint6" pos="0 0 0" axis="1 0 0" range="-3.14159 3.14159" actuatorfrcrange="-20 20"/>
                    <geom type="mesh" mesh="link6-7"/>
                      <body name="tool0"
                        pos="0.158 0 0"
                        euler="-1.5708 0 -1.5708">
                      </body>
                      <camera name="camera_joint" pos="0.0471 0 0.063314" xyaxes="0 -1 0  0 0 1"/> 
                      <geom type="sphere" size="0.005" pos="0.0471 0 0.063314" rgba="1 0 0 1"/>
                            
                    <body name="finger_left">
                      <inertial pos="0.08 0.04 0" quat="0.5 0.5 0.5 0.5" mass="0.05" diaginertia="3e-05 3e-05 2e-05"/>
                      <joint name="gripper_left" pos="0 0 0" axis="0 1 0" type="slide" range="-0.045 0.001" actuatorfrcrange="-20 20"/>
                      <geom name= "finger_left" type="mesh" mesh="finger_left"/>
                    </body>

                    <body name="finger_right">
                      <inertial pos="0.08 -0.04 0" quat="0.5 0.5 0.5 0.5" mass="0.05" diaginertia="3e-05 3e-05 2e-05"/>
                      <joint name="gripper_right" pos="0 0 0" axis="0 -1 0" type="slide" range="-0.045 0.001" actuatorfrcrange="-20 20"/>
                      <geom name="finger_right" type="mesh" mesh="finger_right"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
    </worldbody>

